{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "implementation_patch_plan",
  "description": "Stage 10 — Ordered patch sequence a build agent applies file-by-file to produce runnable code from the implementation_plan blueprint. Every patch entry touches exactly one file. No code appears in this artifact — only precise, unambiguous build instructions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "artifact_name",
    "version",
    "produced_by",
    "timestamp",
    "status",
    "patch_objective",
    "source_pass",
    "target_files",
    "patch_sequence",
    "naming_registry",
    "animation_contracts",
    "acceptance_signals",
    "patch_notes"
  ],
  "properties": {
    "job_id":        { "type": "string", "minLength": 1 },
    "artifact_name": { "type": "string", "const": "implementation_patch_plan" },
    "version":       { "type": "integer", "minimum": 1 },
    "produced_by":   { "type": "string", "const": "Implementation Patch Plan Agent" },
    "timestamp":     { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["pass", "needs_review"]
    },

    "patch_objective": {
      "type": "string",
      "minLength": 1,
      "description": "One sentence: what this patch plan delivers that the current codebase does not yet have."
    },

    "source_pass": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pass_number", "pass_label", "features_added"],
      "properties": {
        "pass_number":    { "type": "integer", "minimum": 1 },
        "pass_label":     { "type": "string", "minLength": 1 },
        "features_added": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },

    "target_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file_path", "operation", "current_state", "post_patch_state"],
        "properties": {
          "file_path":        { "type": "string", "minLength": 1 },
          "operation": {
            "type": "string",
            "enum": ["create", "edit", "do_not_touch"]
          },
          "current_state":    { "type": "string", "minLength": 1 },
          "post_patch_state": { "type": "string", "minLength": 1 }
        }
      }
    },

    "patch_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "patch_id",
          "file_path",
          "patch_type",
          "change_description",
          "location_hint",
          "named_elements",
          "depends_on",
          "rationale"
        ],
        "properties": {
          "patch_id": {
            "type": "string",
            "minLength": 1,
            "description": "Unique identifier in format P{pass}-{sequence:02d}, e.g. P3-01."
          },
          "file_path": { "type": "string", "minLength": 1 },
          "patch_type": {
            "type": "string",
            "enum": [
              "add_constant",
              "add_state_variable",
              "add_hook",
              "add_ref",
              "add_component",
              "add_css_class",
              "add_keyframe",
              "add_css_custom_property",
              "edit_component_logic",
              "edit_css_rule",
              "edit_render_output",
              "edit_event_handler",
              "wire_callback",
              "wire_ref",
              "conditional_render",
              "remove_rule"
            ]
          },
          "change_description": {
            "type": "string",
            "minLength": 1,
            "description": "Precise prose description of what this patch does. No code — specific enough that a builder has zero ambiguity about what to write."
          },
          "location_hint": {
            "type": "string",
            "minLength": 1,
            "description": "Where in the file this change goes: component name, CSS selector, function name, 'top of file', 'after P3-02', etc."
          },
          "named_elements": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Exact names a builder must use. Format: 'type:name', e.g. 'css_class:customer-happy', 'prop:roundState', 'keyframe:character-bounce'."
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "patch_ids that must be applied before this patch. Empty array means no dependency."
          },
          "rationale": {
            "type": "string",
            "minLength": 1,
            "description": "Why this change is needed — ties back to prototype_ui_spec or implementation_plan."
          }
        }
      }
    },

    "naming_registry": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "name_type", "file_path", "purpose"],
        "properties": {
          "name":      { "type": "string", "minLength": 1 },
          "name_type": {
            "type": "string",
            "enum": [
              "css_class",
              "css_custom_property",
              "keyframe",
              "state_variable",
              "ref",
              "prop",
              "callback",
              "constant",
              "component"
            ]
          },
          "file_path": { "type": "string", "minLength": 1 },
          "purpose":   { "type": "string", "minLength": 1 }
        }
      },
      "description": "Authoritative registry of every name introduced in this patch plan. A build agent must not invent alternative names."
    },

    "animation_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "animation_id",
          "trigger",
          "duration_ms",
          "easing",
          "css_custom_properties",
          "keyframe_name",
          "owner_file",
          "element_selector",
          "dom_measurement_required"
        ],
        "properties": {
          "animation_id":             { "type": "string", "minLength": 1 },
          "trigger":                  { "type": "string", "minLength": 1 },
          "duration_ms":              { "type": "integer", "minimum": 0 },
          "easing":                   { "type": "string", "minLength": 1 },
          "css_custom_properties":    { "type": "array", "items": { "type": "string" } },
          "keyframe_name":            { "type": "string", "minLength": 1 },
          "owner_file":               { "type": "string", "minLength": 1 },
          "element_selector":         { "type": "string", "minLength": 1 },
          "dom_measurement_required": { "type": "boolean" }
        }
      }
    },

    "acceptance_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signal_id", "description", "observable_in_browser", "related_patches"],
        "properties": {
          "signal_id":             { "type": "string", "minLength": 1 },
          "description":           { "type": "string", "minLength": 1 },
          "observable_in_browser": { "type": "string", "minLength": 1 },
          "related_patches":       { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "patch_notes": {
      "type": "string",
      "minLength": 1,
      "description": "Implementation decisions, constraints, sequencing rationale, and anything a build agent must know before starting."
    }
  }
}
