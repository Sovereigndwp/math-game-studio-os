{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "implementation_plan",
  "description": "Stage 9 — Engineering blueprint that translates prototype_ui_spec into buildable code structure. Defines what to build now, what to stub, what files are needed, component responsibilities, state ownership, animation contracts, and test targets. Does NOT contain code — that is implementation_patch_plan.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "artifact_name",
    "version",
    "produced_by",
    "timestamp",
    "status",
    "implementation_goal",
    "build_scope",
    "file_plan",
    "component_plan",
    "state_plan",
    "data_config_plan",
    "animation_plan",
    "test_plan",
    "integration_notes",
    "risks_and_unknowns",
    "open_questions"
  ],
  "properties": {
    "job_id":        { "type": "string", "minLength": 1 },
    "artifact_name": { "type": "string", "const": "implementation_plan" },
    "version":       { "type": "integer", "minimum": 1 },
    "produced_by":   { "type": "string", "const": "Implementation Plan Agent" },
    "timestamp":     { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["pass", "revise", "reject"]
    },

    "implementation_goal": {
      "type": "string",
      "minLength": 1,
      "description": "One clear sentence: what this implementation plan is building and for whom."
    },

    "build_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["must_build_now", "can_stub", "must_not_build_now"],
      "properties": {
        "must_build_now": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Features/systems that must be fully implemented in this pass."
        },
        "can_stub": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Features that can be placeholder/stub implementations for now."
        },
        "must_not_build_now": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Features explicitly deferred. Do not build these yet."
        }
      }
    },

    "file_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "action", "purpose"],
        "properties": {
          "path":    { "type": "string" },
          "action":  { "type": "string", "enum": ["create", "update", "reuse"] },
          "purpose": { "type": "string" }
        }
      }
    },

    "component_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_name", "responsibility", "inputs", "outputs"],
        "properties": {
          "component_name": { "type": "string" },
          "responsibility": { "type": "string" },
          "inputs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Props or data this component receives."
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Callbacks or events this component emits."
          }
        }
      }
    },

    "state_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_state", "derived_state", "state_ownership_notes"],
      "properties": {
        "local_state": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "initial_value", "updated_by"],
            "properties": {
              "name":          { "type": "string" },
              "type":          { "type": "string" },
              "initial_value": { "type": "string" },
              "updated_by":    { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "derived_state": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "derived_from", "description"],
            "properties": {
              "name":         { "type": "string" },
              "derived_from": { "type": "string" },
              "description":  { "type": "string" }
            }
          }
        },
        "state_ownership_notes": {
          "type": "string",
          "description": "Which component/hook owns authoritative state and why."
        }
      }
    },

    "data_config_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config_objects", "hardcoded_only_if_temporary", "future_extraction_notes"],
      "properties": {
        "config_objects": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "file_path", "description"],
            "properties": {
              "name":        { "type": "string" },
              "file_path":   { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "Named config objects: LEVELS, TARGET_SEQUENCE, ROUND_STATES, timing maps, etc."
        },
        "hardcoded_only_if_temporary": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Values that are hardcoded in this pass but should be data-driven later."
        },
        "future_extraction_notes": {
          "type": "string",
          "description": "What should move to external config/data files in a future pass."
        }
      }
    },

    "animation_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["animation_name", "owner", "trigger", "implementation_note"],
        "properties": {
          "animation_name":      { "type": "string" },
          "owner":               { "type": "string", "description": "Component or file that owns this animation." },
          "trigger":             { "type": "string", "description": "What event/state change triggers this animation." },
          "implementation_note": { "type": "string", "description": "How to implement: CSS keyframe, Framer, etc." }
        }
      }
    },

    "test_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_checks", "logic_checks", "edge_case_checks"],
      "properties": {
        "manual_checks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Player-observable behaviors to verify in the browser."
        },
        "logic_checks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "State machine behaviors and math accuracy to verify."
        },
        "edge_case_checks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Edge cases: rapid tapping, boundary values, replay, etc."
        }
      }
    },

    "integration_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Decisions made, constraints accepted, things a builder must know before touching code."
    },

    "risks_and_unknowns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Engineering risks and open technical questions that could affect the build."
    },

    "open_questions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Design or scoping questions that remain unresolved — flag for review."
    }
  }
}
